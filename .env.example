NEXT_PUBLIC_SITE_URL=https://azurmenton.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_API_HOST=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional weather widget configuration. Leave blank if the weather widget is not enabled.
WEATHER_PROVIDER=open-meteo
WEATHER_LATITUDE=43.7745
WEATHER_LONGITUDE=7.4975

# Optional email delivery for booking requests.
# Never commit real API keys. Set these in Vercel project environment variables.
# Production booking request delivery requires RESEND_API_KEY and BOOKING_REQUEST_TO_EMAIL.
RESEND_API_KEY=
BOOKING_REQUEST_TO_EMAIL=
BOOKING_REQUEST_FROM_EMAIL=
# Optional override for the hidden operational copy. Defaults to a.biletskiy@gmail.com.
BOOKING_REQUEST_BCC_EMAIL=
